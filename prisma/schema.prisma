// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider            = "prisma-client"
  output              = "../libs/database/src/generated/prisma"
  moduleFormat        = "cjs"
  importFileExtension = "ts"
}

datasource db {
  provider = "postgresql"
}

model Account {
  id            String @id @default(cuid())
  name          String
  email         String @unique
  password_hash String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  projects Project[]
}

model Project {
  id          String  @id @default(cuid())
  name        String
  description String
  account_id  String
  account     Account @relation(fields: [account_id], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  apiKeys       ProjectApiKey[]
  webhooks      WebhookEndpoint[]
  customers     Customer[]
  subscriptions Subscription[]

  prices Price[]

  plans Plan[]

  paymentMethods PaymentMethod[]

  invoices Invoice[]
}

model ProjectApiKey {
  key_hash   String
  key_prefix String

  project_id String
  project    Project @relation(references: [id], fields: [project_id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@id([key_prefix, key_hash])
}

model WebhookEndpoint {
  id             String  @id @default(cuid())
  url            String
  signing_secret String
  is_active      Boolean @default(true)
  project_id     String
  project        Project @relation(references: [id], fields: [project_id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

model Plan {
  id          String @id @default(cuid())
  name        String
  description String

  is_active Boolean @default(true)

  project_id String
  project    Project @relation(fields: [project_id], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  prices Price[]
}

enum Interval {
  day
  week
  month
  year
}

model Price {
  id String @id @default(cuid())

  plan_id    String
  plan       Plan    @relation(fields: [plan_id], references: [id], onDelete: Cascade)
  project_id String
  project    Project @relation(fields: [project_id], references: [id], onDelete: Cascade)

  unit_amount            Int
  billing_interval       Interval
  billing_interval_count Int
  is_active              Boolean  @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  subscriptions Subscription[]
}

model Customer {
  id         String @id @default(cuid())
  project_id String

  project Project @relation(references: [id], fields: [project_id], onDelete: Cascade)

  email     String
  name      String
  metadata  Json    @default("{}")
  is_active Boolean @default(true)

  subscriptions  Subscription[]
  paymentMethods PaymentMethod[]
  invoices       Invoice[]

  @@unique([project_id, email])
}

model PaymentMethod {
  id String @id @default(cuid())

  project_id String
  project    Project @relation(fields: [project_id], references: [id], onDelete: Cascade)

  customer_id String
  customer    Customer @relation(fields: [customer_id], references: [id], onDelete: Cascade)

  provider_token String
  last4          String
  brand          String

  is_default Boolean @default(false)

  createdAt DateTime @default(now())

  subscriptions Subscription[]
}

enum SubscriptionStatus {
  trialing
  active
  past_due
  canceled
  unpaid
  incomplete
}

model Subscription {
  id String @id @default(cuid())

  project_id        String
  customer_id       String
  price_id          String
  payment_method_id String? // Optional so the subscription can be created before card capture

  project       Project        @relation(fields: [project_id], references: [id])
  customer      Customer       @relation(fields: [customer_id], references: [id])
  price         Price          @relation(fields: [price_id], references: [id])
  paymentMethod PaymentMethod? @relation(fields: [payment_method_id], references: [id])

  status SubscriptionStatus

  current_period_start DateTime
  current_period_end   DateTime

  cancel_at_period_end Boolean   @default(false)
  canceled_at          DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  invoices Invoice[]
}

enum InvoiceStatus {
  pending
  paid
  failed
  void
}

model Invoice {
  id String @id @default(cuid())

  project_id String
  project    Project @relation(fields: [project_id], references: [id], onDelete: Cascade)

  customer_id String
  customer    Customer @relation(fields: [customer_id], references: [id], onDelete: Cascade)

  subscription_id String
  subscription    Subscription @relation(fields: [subscription_id], references: [id], onDelete: Cascade)

  amount Int

  status InvoiceStatus

  due_at  DateTime
  paid_at DateTime?

  createdAt DateTime @default(now())

  paymentAttempts PaymentAttempt[]
}

enum PaymentAttemptStatus {
  pending
  successful
  failed
}

model PaymentAttempt {
  id String @id @default(cuid())

  invoice_id String
  invoice    Invoice @relation(fields: [invoice_id], references: [id], onDelete: Cascade)

  provider_reference String?

  status PaymentAttemptStatus

  error_message String?

  createdAt DateTime @default(now())
}
